@startuml US-20
hide circle
skinparam classAttributeIconSize 0
title US-20: Game Suspension
enum GameStatus {
  pending
  approved
  rejected
  suspended
}

class User {
  +userId: UUID
  +email: string
  +username: string
  +passwordHash: string
  +role: Role
  +isBanned: bool
  +displayName: string
  +avatarUrl: string
}

class Game {
  +gameId: UUID
  +title: string
  +price: decimal
  +discountPercent: int
  +status: GameStatus
  +rejectionReason: string
}

@enduml
