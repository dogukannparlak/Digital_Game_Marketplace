@startuml US-19
hide circle
skinparam classAttributeIconSize 0
title US-19: Developer Verification
class User {
  +userId: UUID
  +email: string
  +username: string
  +passwordHash: string
  +role: Role
  +isBanned: bool
  +displayName: string
  +avatarUrl: string
}

class Developer {
  +developerId: UUID
  +name: string
  +isVerified: bool
}

@enduml
