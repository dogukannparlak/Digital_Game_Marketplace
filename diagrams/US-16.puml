@startuml US-16
hide circle
skinparam classAttributeIconSize 0
title US-16: Game Approval Workflow
enum GameStatus {
  pending
  approved
  rejected
  suspended
}

class User {
  +userId: UUID
  +email: string
  +username: string
  +passwordHash: string
  +role: Role
  +isBanned: bool
  +displayName: string
  +avatarUrl: string
}

class Developer {
  +developerId: UUID
  +name: string
  +isVerified: bool
}

class Game {
  +gameId: UUID
  +title: string
  +price: decimal
  +discountPercent: int
  +status: GameStatus
  +rejectionReason: string
}

Developer "1" --> "0..*" Game : publishes
note right of Game
status: pending/approved/rejected/suspended
rejectionReason required when rejected
end note
@enduml
