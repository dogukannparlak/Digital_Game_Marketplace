@startuml US-18
hide circle
skinparam classAttributeIconSize 0
title US-18: Role Management
enum Role {
  user
  developer
  admin
}

class User {
  +userId: UUID
  +email: string
  +username: string
  +passwordHash: string
  +role: Role
  +isBanned: bool
  +displayName: string
  +avatarUrl: string
}

@enduml
